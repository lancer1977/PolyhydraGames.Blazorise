@using System.Globalization
@using MudBlazor

<MudDialog>
    <DialogContent>
        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <MudText Typo="Typo.body1">@Message</MudText>
        }

        <MudTextField T="string" @bind-Value="_value" Immediate="true" AutoFocus="true" />
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="Cancel">@NegativeButton</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">@PositiveButton</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private string _value = string.Empty;

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public string InitialValue { get; set; } = string.Empty;
    [Parameter] public bool IsInteger { get; set; }
    [Parameter] public int? MinInt { get; set; }
    [Parameter] public int? MaxInt { get; set; }
    [Parameter] public int DefaultInt { get; set; }
    [Parameter] public string PositiveButton { get; set; } = "OK";
    [Parameter] public string NegativeButton { get; set; } = "Cancel";

    protected override void OnParametersSet()
    {
        _value = InitialValue;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Submit()
    {
        if ( IsInteger )
        {
            if ( !int.TryParse( _value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed ) )
            {
                MudDialog.Close( DialogResult.Ok( DefaultInt ) );
                return;
            }

            if ( MinInt is not null && parsed < MinInt.Value )
            {
                MudDialog.Close( DialogResult.Ok( DefaultInt ) );
                return;
            }

            if ( MaxInt is not null && parsed > MaxInt.Value )
            {
                MudDialog.Close( DialogResult.Ok( DefaultInt ) );
                return;
            }

            MudDialog.Close( DialogResult.Ok( parsed ) );
            return;
        }

        MudDialog.Close( DialogResult.Ok( _value ) );
    }
}
